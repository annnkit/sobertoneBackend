# Database
DATABASE_URL=postgresql://sobertone_user:beuwLETfYfBnnUJ13piMIa5ON1THCQ7D@dpg-d7p3g0favr4c73d2bim0-a.singapore-postgres.render.com/sobertone

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AI Provider: Groq (free) ──────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_...your-key-here...
GROQ_MODEL=llama-3.1-70b-versatile

# ── Vector Memory: Optional ───────────────────────────────
# Only needed for personalized AI memory. Leave blank to skip.
# OpenAI key for embeddings: https://platform.openai.com
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone for vector storage: https://app.pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX_NAME=sobertone-memory
PINECONE_ENVIRONMENT=us-east-1

# App
APP_ENV=development
